                <zone fixed-size='280' h='94375' id='8' image-file-url='https://www.zastavki.com/pictures/originals/2017Sport___Russia_2018_FIFA_World_Cup_FIFA_World_Cup_2018_logo_on_a_white_background__112863_.jpg' is-centered='0' is-fixed='true' is-scaled='1' type-v2='bitmap' w='91100' x='27400' y='1125'>
